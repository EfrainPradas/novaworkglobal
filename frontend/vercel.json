{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://3.145.4.238.nip.io/novaworkglobal-api/api/$1"
        },
        {
            "source": "/novaworkglobal-api/(.*)",
            "destination": "https://3.145.4.238.nip.io/novaworkglobal-api/$1"
        },
        {
            "source": "/((?!videos/).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/videos/(.*)",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "video/mp4"
                },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                },
                {
                    "key": "Accept-Ranges",
                    "value": "bytes"
                }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                }
            ]
        }
    ]
}