# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Backend ───────────────────────────────────────────────────
PORT=5001
NODE_ENV=development
OPENAI_API_KEY=your-openai-key

# ── Stripe (test mode only for sandbox) ──────────────────────
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Webhook secret — generated by bootstrap script or Stripe CLI
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# Portal config ID — generated by bootstrap script
STRIPE_PORTAL_CONFIG_ID=bpc_XXXXXXXXXXXXXXXXXXXXXXXX

# ── Stripe Price IDs (generated by bootstrap script) ─────────
PRICE_MEMBERSHIP_ESENCIALES=price_XXXXXXXXXXXXXXXXXXXXXXXX
PRICE_MEMBERSHIP_MOMENTUM=price_XXXXXXXXXXXXXXXXXXXXXXXX
PRICE_MEMBERSHIP_VANGUARD=price_XXXXXXXXXXXXXXXXXXXXXXXX
PRICE_ADDON_COACHING_EMAIL=price_XXXXXXXXXXXXXXXXXXXXXXXX
PRICE_ADDON_COACH_PLUS_EMAIL=price_XXXXXXXXXXXXXXXXXXXXXXXX
PRICE_ADDON_SESSION_1ON1=price_XXXXXXXXXXXXXXXXXXXXXXXX

# ── Bootstrap script config ──────────────────────────────────
APP_URL=http://localhost:5173
# Set WEBHOOK_URL only if you have a public endpoint (e.g., ngrok)
# Leave empty for local dev — use Stripe CLI instead
WEBHOOK_URL=
